<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BibliotecaAvalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="BibliotecaAvalonia.Views.VerValoracionesWindow"
        Title="Valoraciones del artículo"
        x:DataType="vm:VerValoracionesViewModel"
        Width="600"
        Height="400">

    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Valoraciones"
                   FontSize="22"
                   FontWeight="Bold"/>

        <ListBox ItemsSource="{Binding valoraciones}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding usuarioId, StringFormat='Usuario Id: {0}'}"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding puntuacion, StringFormat='Puntuación: {0}'}"/>
                            <TextBlock Text="{Binding comentario, StringFormat='Comentario: {0}'}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="Cerrar"
                HorizontalAlignment="Center"
                Click="Cerrar_Click"/>
    </StackPanel>
</Window>
