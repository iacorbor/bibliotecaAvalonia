<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BibliotecaAvalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="BibliotecaAvalonia.Views.CrearArticuloWindow"
        x:DataType="vm:CrearArticuloViewModel"
        Title="Crear artículo"
        Width="500"
        Height="700">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">

            <TextBlock Text="Crear / Editar artículo"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Text="Tipo de artículo"/>
            <ComboBox ItemsSource="{Binding tiposArticulo}"
                      SelectedIndex="{Binding tipoSeleccionado}"/>

            <TextBlock Text="Título"/>
            <TextBox Text="{Binding titulo}"/>

            <TextBlock Text="Año"/>
            <TextBox Text="{Binding anioTexto}"/>

            <TextBlock Text="Fecha de adquisición"/>
            <DatePicker SelectedDate="{Binding fechaAdquisicion}"/>

            <TextBlock Text="Autor"/>
            <TextBox Text="{Binding autor}"/>

            <StackPanel IsVisible="{Binding esLibro}" Spacing="10">
                <TextBlock Text="ISBN"/>
                <TextBox Text="{Binding isbn}"/>

                <CheckBox Content="Prestado"
                          IsChecked="{Binding prestado}"/>
            </StackPanel>

            <StackPanel IsVisible="{Binding esAudiolibro}" Spacing="10">
                <TextBlock Text="Fecha inicio disponibilidad"/>
                <DatePicker SelectedDate="{Binding fechaInicioDisp}"/>

                <TextBlock Text="Fecha fin disponibilidad"/>
                <DatePicker SelectedDate="{Binding fechaFinDisp}"/>
            </StackPanel>

            <TextBlock Text="{Binding mensajeError}"
                       Foreground="Red"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button Content="Guardar" Click="Guardar_Click"/>
                <Button Content="Cancelar" Click="Cancelar_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>